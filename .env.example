# Supabase (project: lovu-ml-analysis, ref: aimmwwireujuhkuolgwv)
NEXT_PUBLIC_SUPABASE_URL=https://aimmwwireujuhkuolgwv.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key: NEVER exposed via MCP by design. Copy from
# Supabase Dashboard > Project Settings > API > service_role.
# Server-side only (panel read client, Edge Functions). Never commit.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Livre OAuth app (registered at developers.mercadolivre.com.br)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Fixed HTTPS redirect URI registered with the ML app (see T1.5)
ML_REDIRECT_URI=https://lovu-ml-analysis.vercel.app/api/ml-auth/callback

# Panel access protection (T14) — HTTP Basic Auth via Next middleware
PANEL_BASIC_AUTH_USER=
PANEL_BASIC_AUTH_PASSWORD=
